{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 300
    },
    "api/**/*.ts": {
      "maxDuration": 300
    }
  }
}
